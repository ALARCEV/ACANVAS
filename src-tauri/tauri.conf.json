{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ACANVAS",
  "version": "0.1.0",
  "identifier": "com.acanvas.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ACANVAS",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": []
  }
}
