{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ACANVAS",
  "version": "0.1.0",
  "identifier": "com.acanvas.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ACANVAS",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3MkRGNUZEMjZFQTEwNTEKUldSUkVPb20vZlV0RitXaDNFajRpUWY3eHNGYW5EOWNNNDNMV2R1dW5Gd2VvMUtIYWlwWVVDSVYK",
      "endpoints": [
        "https://github.com/ALARCEV/ACANVAS/releases/latest/download/latest.json"
      ]
    }
  }
}
